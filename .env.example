# TheOddsAPI key — get one at https://the-odds-api.com
ODDS_API_KEY=your_key_here

# Optional overrides
SHINE_REGIONS=us,uk,eu          # bookmaker regions
SHINE_ODDS_FORMAT=american      # american | decimal
SHINE_CACHE_TTL=120              # seconds to cache odds responses
SHINE_CACHE_DIR=.shine_cache
